# Vite development server port
VITE_DEV_PORT=5175
# Backend used by the Vite /api proxy
VITE_API_PROXY_TARGET=http://localhost:8080
# Public SignalR hub URL embedded in the browser bundle
VITE_DRONE_HUB_URL=http://localhost:8080/hubs/drone
VITE_NOTIFICATION_HUB_URL=http://localhost:8080/hubs/notifications
# Public URL of the customer portal
VITE_CUSTOMER_APP_URL=http://localhost:5173
